# ============================================================
#  XISSIN MONOREPO — .gitignore
#  Prevents secrets, build artifacts, and junk from being
#  committed to the public GitHub repository.
# ============================================================

# ── Environment / Secrets ────────────────────────────────────
.env
.env.*
*.env
.env.local
.env.production
.env.development
secrets.json
secrets.yaml
secrets.yml

# ── Python ───────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
*.egg
pip-log.txt
.tox/
.cache/
*.coverage
.coverage
htmlcov/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ── Virtual Environments ─────────────────────────────────────
venv/
env/
ENV/
.venv/
.virtualenv/

# ── Flutter / Dart ───────────────────────────────────────────
app/build/
app/.dart_tool/
app/.flutter-plugins
app/.flutter-plugins-dependencies
app/.packages
app/pubspec.lock
*.g.dart
*.freezed.dart
app/android/.gradle/
app/android/local.properties
app/android/key.properties
app/android/app/google-services.json
app/ios/Flutter/flutter_export_environment.sh
app/ios/Pods/
app/ios/.symlinks/
app/.idea/
*.iml

# ── Admin (Streamlit) ─────────────────────────────────────────
admin/.streamlit/secrets.toml

# ── APK / Build outputs ───────────────────────────────────────
*.apk
*.aab
*.ipa
*.dSYM.zip
*.dSYM

# ── IDE / OS ─────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# ── Logs ─────────────────────────────────────────────────────
*.log
logs/
npm-debug.log*

# ── Node ─────────────────────────────────────────────────────
node_modules/
