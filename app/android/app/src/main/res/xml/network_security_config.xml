<?xml version="1.0" encoding="utf-8"?>
<!--
  network_security_config.xml
  Allows plain HTTP (cleartext) ONLY for ip-api.com.
  The free tier of ip-api.com does not support HTTPS.
  All other domains remain HTTPS-only.
-->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">ip-api.com</domain>
    </domain-config>
</network-security-config>
